+
+/* --- compact webdisk tuning --- */
+.dust-canvas {
+  opacity: 0.32;
+}
+.curtain-overlay {
+  opacity: 0.28;
+}
+.light-gradient {
+  opacity: 0.45;
+}
+.app-shell {
+  padding: 16px !important;
+}
+.topbar.dream-topbar {
+  grid-template-columns: 220px minmax(280px, 1fr) auto !important;
+  gap: 12px;
+  padding: 12px 14px;
+  min-height: 68px;
+}
+.brand-block {
+  gap: 10px;
+}
+.brand-logo {
+  width: 42px;
+  height: 42px;
+  border-radius: 14px;
+}
+.logo-glow {
+  inset: 10px;
+}
+.orbit-a {
+  inset: 5px 8px;
+  animation-duration: 18s;
+}
+.orbit-b {
+  inset: 8px 5px;
+  animation-duration: 22s;
+}
+.sidebar-toggle {
+  width: 36px;
+  height: 36px;
+  border-radius: 12px;
+}
+.brand-copy {
+  gap: 0;
+}
+.brand-copy strong {
+  font-size: 13px !important;
+  letter-spacing: 0.14em;
+}
+.brand-copy span {
+  font-family: Inter, 'PingFang SC', sans-serif !important;
+  font-size: 12px !important;
+  line-height: 1.45;
+}
+.global-search-shell.dream-search-shell,
+.repo-status-pill,
+.user-menu-button {
+  min-height: 40px;
+  border-radius: 14px;
+}
+.global-search-shell {
+  padding: 0 10px;
+}
+.global-search-input {
+  font-size: 13px;
+}
+.global-search-shortcut {
+  min-width: 34px;
+  height: 24px;
+  font-size: 10px;
+}
+.repo-status-pill {
+  gap: 8px;
+  padding: 0 12px;
+}
+.repo-status-pill strong,
+.repo-status-pill span,
+.user-menu-text,
+.field-label {
+  font-size: 12px;
+}
+.user-menu {
+  min-width: 180px;
+  border-radius: 14px;
+}
+.user-menu button {
+  font-size: 13px;
+  padding: 10px 12px;
+}
+.drive-layout {
+  grid-template-columns: 250px minmax(0, 1fr) !important;
+  gap: 16px !important;
+}
+.drive-layout.sidebar-collapsed {
+  grid-template-columns: 76px minmax(0, 1fr) !important;
+}
+.drive-main,
+.drive-sidebar {
+  gap: 14px;
+}
+.card,
+.drawer-panel,
+.inspector-drawer,
+.settings-modal {
+  border-radius: 20px !important;
+}
+.nav-card {
+  padding: 12px;
+}
+.drive-nav-item {
+  min-height: 44px;
+  border-radius: 14px;
+  grid-template-columns: 32px 1fr auto;
+}
+.drive-nav-icon {
+  width: 32px;
+  height: 32px;
+  border-radius: 10px;
+}
+.drive-nav-label {
+  font-family: Inter, 'PingFang SC', sans-serif !important;
+  font-size: 14px;
+  font-weight: 600;
+}
+.drive-nav-count {
+  font-size: 12px;
+}
+.compact-overview-card {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 14px;
+  padding: 16px 18px !important;
+  background: linear-gradient(180deg, rgba(255,255,255,0.5), rgba(255,252,248,0.34));
+}
+.workspace-overview-copy {
+  display: grid;
+  gap: 8px;
+  max-width: 72ch;
+}
+.compact-overview-card h1 {
+  margin: 0;
+  max-width: none;
+  font-size: clamp(22px, 2.4vw, 30px) !important;
+  line-height: 1.2;
+  letter-spacing: 0.02em;
+  font-weight: 500;
+}
+.workspace-overview-text {
+  font-size: 13px !important;
+  line-height: 1.6;
+}
+.workspace-overview-actions {
+  display: flex;
+  align-items: center;
+  justify-content: flex-end;
+  flex-wrap: wrap;
+  gap: 8px;
+  min-width: 240px;
+}
+.explorer-toolbar-card {
+  padding: 16px 18px !important;
+}
+.toolbar-title-row {
+  margin-bottom: 12px;
+}
+.section-title-row h2,
+.drawer-header h2,
+.settings-modal-head h2 {
+  font-size: 18px;
+}
+.section-title-row p,
+.settings-modal-head p,
+.workspace-text {
+  font-size: 13px !important;
+  line-height: 1.6;
+}
+.toolbar-row {
+  gap: 10px;
+}
+.grid-controls-row {
+  gap: 10px;
+}
+.button,
