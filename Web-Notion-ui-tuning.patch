+  font-size: 13px;
+}
+.button,
+.view-mode-button {
+  padding: 0 12px;
+}
+.select-input {
+  padding: 0 34px 0 12px;
+}
+.breadcrumb-bar,
+.drop-hint-box,
+.summary-chip,
+.pill,
+.status-badge {
+  border-radius: 12px;
+}
+.breadcrumb-button,
+.summary-chip,
+.pill {
+  font-size: 12px;
+}
+.compact-summary-row {
+  margin-top: 10px;
+}
+.compact-summary-row .summary-chip:not(.busy-chip) {
+  color: #6f6256;
+}
+.table-summary-badges,
+.summary-row .summary-chip:nth-child(n+4) {
+  display: none;
+}
+.inspector-drawer.warm-inspector {
+  width: min(360px, 92vw);
+  padding: 16px;
+}
+.settings-modal {
+  width: min(1000px, 95vw);
+  padding: 18px;
+}
+.settings-tabs {
+  gap: 8px;
+  margin-bottom: 14px;
+}
+.settings-tab {
+  min-height: 36px;
+  padding: 0 12px;
+  font-size: 13px;
+}
+.drive-footer.warm-footer.compact-footer {
+  margin-top: 12px;
+  padding: 8px 12px;
+  gap: 10px;
+  font-size: 12px;
+}
+@media (max-width: 1100px) {
+  .compact-overview-card {
+    flex-direction: column;
+    align-items: flex-start;
+  }
+  .workspace-overview-actions {
+    min-width: 0;
+    justify-content: flex-start;
+  }
+}
+@media (max-width: 980px) {
+  .topbar.dream-topbar {
+    grid-template-columns: 1fr !important;
+  }
